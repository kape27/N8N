# n8n Configuration Example
# Copy this file to .env for local development

# Database Configuration (Supabase)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=db.xxxxxxxxxxxxxx.supabase.co
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=your_supabase_password_here
DB_POSTGRESDB_SSL=true

# n8n Configuration
PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678

# Security
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_please
N8N_ENCRYPTION_KEY=your_encryption_key_here

# Localization
GENERIC_TIMEZONE=Europe/Paris
TZ=Europe/Paris
N8N_DEFAULT_LOCALE=fr

# Logging
N8N_LOG_LEVEL=info

# Execution Data Pruning
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168
